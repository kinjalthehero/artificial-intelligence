# Copy this file to .streamlit/secrets.toml for local runs.
# Never commit real secrets to Git.

GROQ_API_KEY = "your_groq_api_key"
SERPAPI_KEY = "your_serpapi_key"

# Optional: protect hosted app with a shared password.
APP_PASSWORD = "optional_app_password"

# Optional: per-session limit when users consume hosted keys.
MAX_REQUESTS_PER_SESSION = 5

